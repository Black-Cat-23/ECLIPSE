# ── ECLIPSE Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values.

# MAST / ExoFOP credentials (optional — public data needs no auth)
MAST_API_TOKEN=your_mast_api_token_here

# Default TESS sector for demo runs
ECLIPSE_DEFAULT_SECTOR=1

# Data directories (absolute or relative to project root)
ECLIPSE_DATA_RAW=data/raw
ECLIPSE_DATA_PROCESSED=data/processed
ECLIPSE_DATA_LABELS=data/labels
ECLIPSE_DATA_SYNTHETIC=data/synthetic
ECLIPSE_CHECKPOINTS=checkpoints

# Database
ECLIPSE_DB_URL=sqlite:///eclipse.db

# API server
ECLIPSE_API_HOST=0.0.0.0
ECLIPSE_API_PORT=8000

# Frontend URL (for CORS)
ECLIPSE_FRONTEND_URL=http://localhost:5173

# Model config (overrides src/utils/config.py defaults)
ECLIPSE_STELLAR_DIM=8
ECLIPSE_D_STREAM_A=128
ECLIPSE_D_STREAM_B=128
ECLIPSE_D_FUSED=256
ECLIPSE_BATCH_SIZE=32
ECLIPSE_LR=3e-4
ECLIPSE_EPOCHS=100

# Physics loss weight
ECLIPSE_PHYSICS_LOSS_WEIGHT=0.2

# Conformal calibration alpha (1 - coverage)
ECLIPSE_CONFORMAL_ALPHA=0.1

# Logging
ECLIPSE_LOG_LEVEL=INFO
ECLIPSE_LOG_FILE=logs/eclipse.log
